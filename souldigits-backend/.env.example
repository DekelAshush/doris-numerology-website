PORT=3001

# From Meta → WhatsApp → API Setup → "Phone number ID" (NOT Business Account ID)
WHATSAPP_PHONE_NUMBER_ID=

# Generated access token from API Setup
WHATSAPP_TOKEN=

# Doris's WhatsApp number — digits only, country code, NO + or leading 0
# Example: 0586690877 becomes 972586690877
# NOT the Phone number ID and NOT the Business Account ID (e.g. 1350412747006044)
WHATSAPP_BUSINESS_NUMBER=

# Secret you choose — same value in Meta webhook "Verify token" field
WHATSAPP_VERIFY_TOKEN=

# One URL, or comma-separated for prod + local (e.g. https://site.vercel.app,http://localhost:3000)
FRONTEND_URL=http://localhost:3000
